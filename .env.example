# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LinkedIn (needed to post directly)
# Get these from: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_ID=your_linkedin_person_id

# Substack (needed to create drafts)
SUBSTACK_URL=https://yourpublication.substack.com
SUBSTACK_EMAIL=your@email.com
SUBSTACK_PASSWORD=your_substack_password
